# Lintro Frontend - Environment Variables (example)
#
# Copy this file to .env and adjust as needed.
#
# In development with the Vite dev proxy (vite.config.js), use "/api"
# so the browser talks same-origin and Vite proxies to the backend.
#
# In production, set this to your full backend URL + /api:
#   VITE_API_URL=https://Lintro-backend.onrender.com/api
VITE_API_URL=/api
